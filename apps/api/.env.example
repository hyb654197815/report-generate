DATABASE_URL="mysql://report:report@localhost:3306/report_generate"
REDIS_URL="redis://localhost:6379"
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY="minio"
MINIO_SECRET_KEY="minio12345"
MINIO_BUCKET="reports"
GOTENBERG_URL="http://localhost:3000"
# * (or empty) = scripts may call any public https host (SSRF rules still block private IPs / localhost).
# Comma-separated = only those hostnames. HTTP_ALLOWLIST_DISABLED=true also disables hostname list.
HTTP_ALLOWLIST_HOSTS="*"
SCRIPT_TIMEOUT_MS=12000
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
# true = 脚本内 AI 不请求真实接口（默认 false）
AI_MOCK_ENABLED=false
AI_DAILY_LIMIT=100
PORT=4000
CORS_ORIGIN="http://localhost:5173"
